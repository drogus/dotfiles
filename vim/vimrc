set nocompatible                " choose no compatibility with legacy vi
syntax enable
colorscheme solarized
set background=light
set encoding=utf-8
set showcmd                     " display incomplete commands

filetype off                   " required!
set rtp+=~/.vim/bundle/vundle/
call vundle#rc()

" let Vundle manage Vundle
Bundle 'gmarik/vundle'
Bundle 'vim-ruby/vim-ruby'
Bundle 'tpope/vim-rails'
Bundle 'wincent/Command-T'
Bundle 'sjbach/lusty'
Bundle 'tpope/vim-fugitive'
Bundle 'tpope/vim-surround'
Bundle 'kchmck/vim-coffee-script'
Bundle 'scrooloose/nerdcommenter'
Bundle 'groenewege/vim-less'
Bundle 'bbommarito/vim-slim'
Bundle 'nono/vim-handlebars'
Bundle 'kien/ctrlp.vim'
Bundle 'sirver/ultisnips'
Bundle 'heartsentwined/vim-emblem'
"Bundle 'tpope/vim-markdown'
"Bundle 'suan/vim-instant-markdown'

filetype plugin indent on       " load file type plugins + indentation

let g:ctrlp_user_command = 'find %s -type f \( ! -path "*/vendor/*" ! -path "*.git/*" ! -path "*/.*" ! -path "*/tmp/*" ! -name "*.so" ! -name "*.swp" ! -name "*.zip" ! -name "*.png" ! -name "*.jpg" ! -path "*/b/*" \)'
let g:ctrlp_working_path_mode = 'ra'

set hidden " For lusty explorer

"" Whitespace
set nowrap                          " don't wrap lines
set tabstop=2 shiftwidth=2          " a tab is two spaces (or set this to 4)
set expandtab                       " use spaces, not tabs (optional)
set backspace=indent,eol,start      " backspace through everything in insert mode
set list                            " Show invisible characters
"" Trailing whitespaces
autocmd BufWritePre * :%s/\s\+$//e  " crlear trailing whitespaces on :w

" List chars
set listchars=""                  " Reset the listchars
set listchars=tab:\ \             " a tab should display as "  ", trailing whitespace as "."
set listchars+=trail:.            " show trailing spaces as dots
set listchars+=extends:>          " The character to show in the last column when wrap is
                                  " off and the line continues beyond the right of the screen
set listchars+=precedes:<         " The character to show in the last column when wrap is
                                  " off and the line continues beyond the right of the screen

"" Searching
set hlsearch                    " highlight matches
set incsearch                   " incremental searching
set ignorecase                  " searches are case insensitive...
set smartcase                   " ... unless they contain at least one capital letter

" cancel highlight with space
nnoremap <silent> <Space> :nohlsearch<Bar>:echo<CR>

" go into command mode with jk
inoremap jk <Left><C-[>

set number
set ruler

" Disable bell
set vb

" over 120 columns highlighting
set textwidth=120
set colorcolumn=+1 " highlight column after 'textwidth'
highlight ColorColumn ctermbg=lightgrey guibg=lightgrey

let mapleader = ","

"" Commenting
"" base comments are from nerd commenter
command! -nargs=? -range=% Cc :normal <line1>ggv<line2>gg<Leader>cc
command! -nargs=? -range=% Cn :normal <line1>ggv<line2>gg<Leader>cn
command! -nargs=? -range=% Ct :normal <line1>ggv<line2>gg<Leader>c<space>
command! -nargs=? -range=% Cm :normal <line1>ggv<line2>gg<Leader>cm
command! -nargs=? -range=% Ci :normal <line1>ggv<line2>gg<Leader>ci
command! -nargs=? -range=% Cs :normal <line1>ggv<line2>gg<Leader>cs
command! -nargs=? -range=% Cy :normal <line1>ggv<line2>gg<Leader>cy
command! -nargs=? -range=% Cl :normal <line1>ggv<line2>gg<Leader>cl
command! -nargs=? -range=% Cb :normal <line1>ggv<line2>gg<Leader>cb
command! -nargs=? -range=% Cu :normal <line1>ggv<line2>gg<Leader>cu

" Command-T config
let g:CommandTMaxFiles=20000
nnoremap <leader>t :CommandT<CR>

" Lusty
nnoremap <leader>b :LustyBufferExplorer<CR>
nnoremap <leader>lb :LustyBufferGrep<CR>
nnoremap <leader>h :LustyFilesystemExplorerFromHere<CR>

" Toggle paste mode
nmap <silent> <F4> :set invpaste<CR>:set paste?<CR>
imap <silent> <F4> <ESC>:set invpaste<CR>:set paste?<CR>

" Next buffer
nmap <silent> ,. :bnext<CR>

" Previous buffer
nmap <silent> ,m :bprev<CR>

" Reselect visual block after indent/outdent
vnoremap < <gv
vnoremap > >gv

" Easy split navigation
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" Make Y behave like other capitals
map Y y$

" automatically reload vimrc when it's saved
au BufWritePost .vimrc so ~/.vimrc

