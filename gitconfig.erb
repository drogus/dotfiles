[user]
	name = Lukasz Sarnacki
	email = lukesarnacki@gmail.com
[color]
	diff = auto
	status = auto
	branch = auto
[core]
	editor = vim
	autocrlf = input
	excludesfile = /Users/sarniak/.gitignore_global
[apply]
	whitespace = nowarn
[format]
	pretty = %C(yellow)%h%Creset %s %C(red)(%an, %cr)%Creset
[alias]
        shift = !$HOME/bin/git-shift
        co = checkout
        plre = pull --rebase
        pl = pull
        ps = push
        ca = commit -a
        ci = commit
        ln = log --no-merges
        lno = log --no-merges --pretty=oneline
        st = status
        br = branch
        unstage = reset HEAD --
        last = log -1 HEAD
[rerere]
        enabled = 1
[heroku]
        account = personal
